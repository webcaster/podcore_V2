{
  "name": "podcore",
  "version": "2.14.2",
  "description": "PodCore - Professionelles Podcast Management System",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm run dev:server\" \"pnpm run dev:client\"",
    "dev:server": "pnpm --dir server run dev",
    "dev:client": "pnpm --dir client run dev",
    "build": "pnpm run build:client && pnpm run build:server && pnpm run sync:public",
    "build:client": "pnpm --dir client run build",
    "build:server": "pnpm --dir server run build",
    "sync:public": "node scripts/sync-public.cjs",
    "start": "node server/dist/index.js",
    "install:all": "pnpm install --frozen-lockfile && pnpm --dir client install --frozen-lockfile && pnpm --dir server install --frozen-lockfile"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1"
  }
}
